<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="200.0" prefWidth="870.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.constructionmanager.manager.ui.controllers.ProjectCreateViewController">

   <children>
       <TextField fx:id="projectName" alignment="CENTER" promptText="Project Name" />
       <TextField fx:id="projectAddress" alignment="CENTER" promptText="Project Address" />
      <ComboBox fx:id="projectType" prefHeight="25.0" prefWidth="874.0" promptText="Select Project Type" />
      <DatePicker fx:id="projectStartDate" prefHeight="25.0" prefWidth="879.0" promptText="Select Project Start Date" />
      <DatePicker fx:id="projectFinishDate" prefHeight="25.0" prefWidth="910.0" promptText="Select Project Finish Date" />
       <Button fx:id="createProjectButton" mnemonicParsing="false" onAction="#createProjectView" prefHeight="30.0" prefWidth="872.0" text="Create" textAlignment="CENTER" />
   </children>
</VBox>
