<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.constructionmanager.manager.ui.controllers.ProjectCreateViewController">

   <children>
       <TextField fx:id="projectName" alignment="CENTER" maxWidth="800.0" prefWidth="600.0" promptText="Project Name">
         <VBox.margin>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </VBox.margin></TextField>
       <TextField fx:id="projectAddress" alignment="CENTER" maxWidth="800.0" prefWidth="600.0" promptText="Project Address">
         <VBox.margin>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </VBox.margin></TextField>
      <ComboBox fx:id="projectType" maxWidth="800.0" prefHeight="25.0" prefWidth="600.0" promptText="Select Project Type">
         <VBox.margin>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </VBox.margin></ComboBox>
      <DatePicker fx:id="projectStartDate" maxWidth="800.0" prefHeight="25.0" prefWidth="600.0" promptText="Select Project Start Date">
         <VBox.margin>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </VBox.margin></DatePicker>
      <DatePicker fx:id="projectFinishDate" maxWidth="800.0" prefHeight="25.0" prefWidth="600.0" promptText="Select Project Finish Date">
         <VBox.margin>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </VBox.margin></DatePicker>
       <Button fx:id="createProjectButton" maxWidth="800.0" mnemonicParsing="false" onAction="#createProjectView" prefHeight="25.0" prefWidth="600.0" text="Create" textAlignment="CENTER">
         <VBox.margin>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </VBox.margin></Button>
   </children>
   <padding>
      <Insets bottom="10.0" left="150.0" right="5.0" />
   </padding>
</VBox>
