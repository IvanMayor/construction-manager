   <bottom>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="tableProcessRequisitionItem" prefHeight="200.0" prefWidth="200.0">
              <columns>
                <TableColumn fx:id="columnPRIId" prefWidth="28.0" text="ID" />
                <TableColumn fx:id="columnPRIPrevBill" minWidth="50.0" prefWidth="120.0" text="Prev Bill" />
                  <TableColumn fx:id="columnPRIThisBill" minWidth="50.0" prefWidth="120.0" text="This Bill" />
                  <TableColumn fx:id="columnPRITotalComplete" minWidth="50.0" prefWidth="120.0" text="Total Complete" />
                  <TableColumn fx:id="columnPRITotalToFinish" minWidth="50.0" prefWidth="120.0" text="Total to Finish" />
                  <TableColumn fx:id="columnPRIRetainage" minWidth="50.0" prefWidth="120.0" text="Retainage" />
                  <TableColumn fx:id="columnPRIPercentComplete" minWidth="50.0" prefWidth="120.0" text="Percent Complete" />
                  <TableColumn fx:id="columnPRIDateCreated" minWidth="50.0" prefWidth="120.0" text="Date Created" />
